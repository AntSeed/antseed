{
  "name": "@antseed/desktop",
  "productName": "AntSeed Desktop",
  "version": "0.1.2",
  "private": true,
  "description": "Desktop app for AntSeed",
  "author": "AntSeed <hello@antseed.ai>",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "brand:electron-dev": "node ./scripts/brand-electron-dev.mjs",
    "ensure:native": "npm run ensure:runtime-native",
    "ensure:runtime-native": "node ./scripts/ensure-runtime-native-modules.mjs",
    "prebuild": "npm run brand:electron-dev && npm run ensure:native && rm -rf dist",
    "predev": "npm run brand:electron-dev && npm run ensure:native",
    "prestart": "npm run brand:electron-dev && npm run ensure:native",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "test:renderer": "vitest run -c vitest.config.ts",
    "test:e2e:chat-smoke": "npm run build && node ./scripts/e2e-chat-smoke.mjs",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json --noEmit",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5174 file:dist/main/main.js file:dist/main/preload.cjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron .",
    "start": "electron .",
    "prepare-dist": "node ./scripts/prepare-dist.mjs",
    "dist": "npm run build && npm run prepare-dist && electron-builder",
    "dist:mac": "npm run build && npm run prepare-dist && electron-builder --mac",
    "release:mac": "npm run build && npm run prepare-dist && node scripts/release-mac.mjs",
    "dist:win": "npm run build && npm run prepare-dist && electron-builder --win",
    "dist:linux": "npm run build && npm run prepare-dist && electron-builder --linux"
  },
  "dependencies": {
    "@antseed/dashboard": "workspace:*",
    "@antseed/node": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@lit/react": "^1.0.8",
    "@mariozechner/mini-lit": "^0.2.0",
    "@mariozechner/pi-ai": "^0.54.2",
    "@mariozechner/pi-coding-agent": "^0.54.2",
    "@mariozechner/pi-web-ui": "^0.55.4",
    "@noble/ed25519": "^2.1.0",
    "@silentbot1/nat-api": "^0.4.9",
    "@walletconnect/ethereum-provider": "^2.17.0",
    "better-sqlite3": "^12.6.2",
    "bittorrent-dht": "^11.0.11",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^16.6.1",
    "ethers": "^6.13.0",
    "fastify": "^5.7.4",
    "lit": "^3.3.1",
    "node-datachannel": "^0.7.0",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.6.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^24.1.3",
    "playwright": "^1.58.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  }
}
