{
  "name": "@antseed/network-stats",
  "version": "0.1.8",
  "description": "Standalone service that polls the AntSeed network and exposes peer/model stats via HTTP",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm run build:server && pnpm run build:web",
    "build:server": "tsc",
    "build:web": "vite build",
    "start": "node dist/index.js",
    "dev": "pnpm run build:server && concurrently -k -n web,tsc,server -c blue,yellow,green \"pnpm dev:web\" \"pnpm dev:tsc\" \"pnpm dev:server\"",
    "dev:web": "vite",
    "dev:tsc": "tsc --watch --preserveWatchOutput",
    "dev:server": "node --watch dist/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json",
    "test": "pnpm run build:server && node --test dist/*.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "ethers": "~6.16.0",
    "express": "^4.18.2"
  },
  "peerDependencies": {
    "@antseed/node": ">=0.1.0"
  },
  "devDependencies": {
    "@antseed/node": "workspace:*",
    "@tanstack/react-query": "^5.94.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "typescript": "^5.3.0",
    "vite": "^6.0.0"
  }
}
