# HTTP server port.
PORT=4000

# Path to the on-disk JSON snapshot written by the DHT poller.
# Defaults to <package>/cache/network.json when unset.
CACHE_PATH=cache/network.json

# Chain ID used to resolve the AntseedStats / AntseedStaking contracts via
# @antseed/node's resolveChainConfig. If the resolved chain has no stats
# contract configured, the on-chain indexer is disabled and only the DHT
# poller runs.
NETWORK_STATS_CHAIN_ID=base-mainnet

# Path to the SQLite database that stores indexed stats events and rollups.
# Parent directories are created automatically.
NETWORK_STATS_DB_PATH=data/network-stats.sqlite

# Alchemy RPC URL for base-mainnet. Required in practice — the public default
# is rate-limited and the indexer assumes Alchemy-class throughput for its
# eth_getLogs and eth_getBlockByNumber calls.
NETWORK_STATS_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Indexer poll interval in milliseconds.
NETWORK_STATS_TICK_INTERVAL_MS=60000

# Maximum block range scanned per indexer tick. Sized for Alchemy
# (10k blocks per eth_getLogs is comfortably under the response-size cap
# for the AntseedStats contract).
NETWORK_STATS_MAX_BLOCKS_PER_TICK=10000
